{
  "name": "@us-all/mlflow-mcp",
  "version": "1.11.2",
  "mcpName": "io.github.us-all/mlflow",
  "description": "MLflow MCP server - experiments, runs, registered models, model versions, traces, and assessments",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mlflow-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/ui','dist/ui',{recursive:true})\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "pnpm run build",
    "smoke": "node dev/smoke.mjs",
    "prepublishOnly": "pnpm run build",
    "pretoken-stats": "pnpm run build",
    "token-stats": "node scripts/measure-tokens.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@us-all/mcp-toolkit": "^1.2.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/us-all/mlflow-mcp-server"
  },
  "license": "MIT"
}
